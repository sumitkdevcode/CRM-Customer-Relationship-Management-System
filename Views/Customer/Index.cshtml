@model IEnumerable<CRM___Customer_Relationship_Management_System.Models.Customer>
@{
    ViewData["Title"] = "Customers";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Customers</h1>
        <p class="page-subtitle">Manage your customer relationships</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i>
        Add Customer
    </a>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-body" style="padding: 1rem;">
        <form method="get" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 200px;">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                       class="form-control" placeholder="Search customers..." />
            </div>
            <div>
                <select name="status" class="form-control form-select" style="min-width: 150px;">
                    <option value="">All Status</option>
                    @foreach (var status in Enum.GetValues<CRM___Customer_Relationship_Management_System.Models.CustomerStatus>())
                    {
                        <option value="@status" selected="@(ViewData["CurrentStatus"]?.ToString() == status.ToString())">@status</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-secondary">
                <i class="fas fa-filter"></i>
                Filter
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-times"></i>
                Clear
            </a>
        </form>
    </div>
</div>

<!-- Customers Table -->
<div class="card">
    <div class="card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>
                                <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" 
                                   asp-route-searchString="@ViewData["CurrentFilter"]" style="color: inherit;">
                                    Company <i class="fas fa-sort"></i>
                                </a>
                            </th>
                            <th>Industry</th>
                            <th>Contact</th>
                            <th>Status</th>
                            <th>Type</th>
                            <th>Deals</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@customer.Id" style="font-weight: 600;">
                                        @customer.CompanyName
                                    </a>
                                    @if (!string.IsNullOrEmpty(customer.City))
                                    {
                                        <br /><small class="text-muted">@customer.City, @customer.Country</small>
                                    }
                                </td>
                                <td>@(customer.Industry ?? "-")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(customer.Email))
                                    {
                                        <a href="mailto:@customer.Email" class="text-muted">@customer.Email</a>
                                    }
                                    @if (!string.IsNullOrEmpty(customer.Phone))
                                    {
                                        <br /><small>@customer.Phone</small>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(customer.Status == CRM___Customer_Relationship_Management_System.Models.CustomerStatus.Active ? "badge-success" : "badge-secondary")">
                                        @customer.Status
                                    </span>
                                </td>
                                <td>
                                    <span class="badge badge-info">@customer.CustomerType</span>
                                </td>
                                <td>
                                    <span style="font-weight: 600;">@customer.Deals.Count</span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 0.5rem;">
                                        <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-sm btn-secondary" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-sm btn-secondary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@customer.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-building"></i>
                <h3>No customers found</h3>
                <p>Add your first customer to get started.</p>
                <a asp-action="Create" class="btn btn-primary" style="margin-top: 1rem;">
                    <i class="fas fa-plus"></i>
                    Add Customer
                </a>
            </div>
        }
    </div>
</div>
