@model CRM___Customer_Relationship_Management_System.Models.Customer
@{
    ViewData["Title"] = Model.CompanyName;
}

<div class="page-header">
    <div>
        <h1 class="page-title">@Model.CompanyName</h1>
        <p class="page-subtitle">Customer Details</p>
    </div>
    <div style="display: flex; gap: 0.5rem;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="fas fa-edit"></i>
            Edit
        </a>
        <a asp-controller="Contact" asp-action="Create" asp-route-customerId="@Model.Id" class="btn btn-secondary">
            <i class="fas fa-user-plus"></i>
            Add Contact
        </a>
        <a asp-controller="Deal" asp-action="Create" asp-route-customerId="@Model.Id" class="btn btn-success">
            <i class="fas fa-handshake"></i>
            Add Deal
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i>
            Back
        </a>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem;">
    <!-- Left Column: Info Card -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Company Info</h3>
            <span class="badge @(Model.Status == CRM___Customer_Relationship_Management_System.Models.CustomerStatus.Active ? "badge-success" : "badge-secondary")">
                @Model.Status
            </span>
        </div>
        <div class="card-body">
            <div style="text-align: center; margin-bottom: 1.5rem;">
                <div style="width: 80px; height: 80px; margin: 0 auto 1rem; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--primary-color);">
                    <i class="fas fa-building"></i>
                </div>
                <h4>@Model.CompanyName</h4>
                <span class="badge badge-info">@Model.CustomerType</span>
            </div>
            
            <div style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
                @if (!string.IsNullOrEmpty(Model.Industry))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Industry</strong>
                        <div>@Model.Industry</div>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.CompanySize))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Company Size</strong>
                        <div>@Model.CompanySize</div>
                    </div>
                }
                
                @if (Model.AnnualRevenue.HasValue)
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Annual Revenue</strong>
                        <div style="color: var(--success-color); font-weight: 600;">$@Model.AnnualRevenue.Value.ToString("N0")</div>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Email</strong>
                        <div><a href="mailto:@Model.Email">@Model.Email</a></div>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Phone</strong>
                        <div>@Model.Phone</div>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.Website))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Website</strong>
                        <div><a href="@Model.Website" target="_blank">@Model.Website</a></div>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.Address))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Address</strong>
                        <div>@Model.Address</div>
                        <div>@Model.City, @Model.State @Model.PostalCode</div>
                        <div>@Model.Country</div>
                    </div>
                }
                
                @if (Model.AssignedTo != null)
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Assigned To</strong>
                        <div>@Model.AssignedTo.FullName</div>
                    </div>
                }
                
                <div style="margin-bottom: 0.75rem;">
                    <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Created</strong>
                    <div>@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Column: Tabs -->
    <div>
        <!-- Contacts -->
        <div class="card" style="margin-bottom: 1.5rem;">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-users" style="margin-right: 0.5rem;"></i>Contacts (@Model.Contacts.Count)</h3>
                <a asp-controller="Contact" asp-action="Create" asp-route-customerId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Add
                </a>
            </div>
            <div class="card-body" style="padding: 0;">
                @if (Model.Contacts.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Title</th>
                                <th>Email</th>
                                <th>Phone</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contact in Model.Contacts)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Contact" asp-action="Details" asp-route-id="@contact.Id">
                                            @contact.FullName
                                        </a>
                                        @if (contact.IsPrimary)
                                        {
                                            <span class="badge badge-primary" style="margin-left: 0.5rem;">Primary</span>
                                        }
                                    </td>
                                    <td>@(contact.JobTitle ?? "-")</td>
                                    <td><a href="mailto:@contact.Email">@contact.Email</a></td>
                                    <td>@(contact.Phone ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-user-plus"></i>
                        <p>No contacts yet</p>
                    </div>
                }
            </div>
        </div>
        
        <!-- Deals -->
        <div class="card" style="margin-bottom: 1.5rem;">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-handshake" style="margin-right: 0.5rem;"></i>Deals (@Model.Deals.Count)</h3>
                <a asp-controller="Deal" asp-action="Create" asp-route-customerId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Add
                </a>
            </div>
            <div class="card-body" style="padding: 0;">
                @if (Model.Deals.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Value</th>
                                <th>Stage</th>
                                <th>Expected Close</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deal in Model.Deals)
                            {
                                <tr>
                                    <td><a asp-controller="Deal" asp-action="Details" asp-route-id="@deal.Id">@deal.Title</a></td>
                                    <td style="font-weight: 600; color: var(--success-color);">$@deal.Value.ToString("N0")</td>
                                    <td><span class="badge badge-primary">@deal.Stage</span></td>
                                    <td>@deal.ExpectedCloseDate?.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-handshake"></i>
                        <p>No deals yet</p>
                    </div>
                }
            </div>
        </div>
        
        <!-- Notes -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-sticky-note" style="margin-right: 0.5rem;"></i>Notes (@Model.Notes.Count)</h3>
                <a asp-controller="Note" asp-action="Create" asp-route-customerId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Add
                </a>
            </div>
            <div class="card-body">
                @if (Model.Notes.Any())
                {
                    @foreach (var note in Model.Notes.OrderByDescending(n => n.IsPinned).ThenByDescending(n => n.CreatedAt))
                    {
                        <div style="padding: 1rem; background: var(--bg-light); border-radius: var(--radius); margin-bottom: 0.75rem; @(note.IsPinned ? "border-left: 3px solid var(--warning-color);" : "")">
                            <div style="font-weight: 600; margin-bottom: 0.5rem;">
                                @if (note.IsPinned) { <i class="fas fa-thumbtack" style="color: var(--warning-color); margin-right: 0.25rem;"></i> }
                                @note.Title
                            </div>
                            <div style="color: var(--text-muted); margin-bottom: 0.5rem;">@note.Content</div>
                            <div style="font-size: 0.75rem; color: var(--text-light);">
                                @note.CreatedBy?.FullName • @note.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-sticky-note"></i>
                        <p>No notes yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
