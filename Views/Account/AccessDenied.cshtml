@{
    ViewData["Title"] = "Access Denied";
}

<div class="auth-container">
    <div class="auth-card" style="text-align: center;">
        <div style="font-size: 4rem; color: var(--danger-color); margin-bottom: 1rem;">
            <i class="fas fa-ban"></i>
        </div>
        <h1 class="auth-title">Access Denied</h1>
        <p class="auth-subtitle">You don't have permission to access this resource.</p>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary" style="margin-top: 1.5rem;">
            <i class="fas fa-home"></i>
            Go to Dashboard
        </a>
    </div>
</div>
