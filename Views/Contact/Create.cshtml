@model CRM___Customer_Relationship_Management_System.Models.Contact
@{
    ViewData["Title"] = "Add Contact";
    var selectedCustomerId = ViewBag.SelectedCustomerId as int?;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add Contact</h1>
        <p class="page-subtitle">Create a new contact</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            
            <div class="form-group">
                <label asp-for="CustomerId" class="form-label"></label>
                <select asp-for="CustomerId" asp-items="@ViewBag.Customers" class="form-control form-select">
                    <option value="">-- Select Customer --</option>
                </select>
                <span asp-validation-for="CustomerId" class="invalid-feedback"></span>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="John" />
                    <span asp-validation-for="FirstName" class="invalid-feedback"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" placeholder="Doe" />
                    <span asp-validation-for="LastName" class="invalid-feedback"></span>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="john@company.com" />
                    <span asp-validation-for="Email" class="invalid-feedback"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" placeholder="+1 (555) 123-4567" />
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="JobTitle" class="form-label"></label>
                    <input asp-for="JobTitle" class="form-control" placeholder="Marketing Manager" />
                </div>
                <div class="form-group">
                    <label asp-for="Department" class="form-label"></label>
                    <input asp-for="Department" class="form-control" placeholder="Marketing" />
                </div>
            </div>
            
            <div class="form-group">
                <label asp-for="Mobile" class="form-label"></label>
                <input asp-for="Mobile" class="form-control" placeholder="Mobile number" />
            </div>
            
            <div class="form-group">
                <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                    <input asp-for="IsPrimary" type="checkbox" />
                    <span>Set as Primary Contact</span>
                </label>
            </div>
            
            <div class="form-group">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional notes..."></textarea>
            </div>
            
            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Save Contact</button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
