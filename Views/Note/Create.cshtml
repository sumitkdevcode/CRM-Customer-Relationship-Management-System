@model CRM___Customer_Relationship_Management_System.Models.Note
@{
    ViewData["Title"] = "Add Note";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add Note</h1>
        <p class="page-subtitle">Create a new note</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="CustomerId" />
            <input type="hidden" asp-for="LeadId" />
            <input type="hidden" asp-for="DealId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            
            <div class="form-group">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Note title" />
                <span asp-validation-for="Title" class="invalid-feedback"></span>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Type" class="form-label"></label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<CRM___Customer_Relationship_Management_System.Models.NoteType>()" class="form-control form-select"></select>
                </div>
                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 2rem;">
                        <input asp-for="IsPinned" type="checkbox" />
                        <span>Pin this note</span>
                    </label>
                </div>
            </div>
            
            @if (!Model.CustomerId.HasValue && !Model.LeadId.HasValue && !Model.DealId.HasValue)
            {
                <h3 style="margin: 2rem 0 1rem; color: var(--primary-color);"><i class="fas fa-link"></i> Link To</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Customer</label>
                        <select name="CustomerId" asp-items="@ViewBag.Customers" class="form-control form-select">
                            <option value="">-- None --</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Lead</label>
                        <select name="LeadId" asp-items="@ViewBag.Leads" class="form-control form-select">
                            <option value="">-- None --</option>
                        </select>
                    </div>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Deal</label>
                    <select name="DealId" asp-items="@ViewBag.Deals" class="form-control form-select">
                        <option value="">-- None --</option>
                    </select>
                </div>
            }
            
            <div class="form-group">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="6" placeholder="Write your note here..."></textarea>
                <span asp-validation-for="Content" class="invalid-feedback"></span>
            </div>
            
            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Save Note</button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
