@model IEnumerable<CRM___Customer_Relationship_Management_System.Models.CrmTask>
@{
    ViewData["Title"] = "My Tasks";
}

<div class="page-header">
    <div>
        <h1 class="page-title">My Tasks</h1>
        <p class="page-subtitle">Tasks assigned to you</p>
    </div>
    <div style="display: flex; gap: 0.5rem;">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-list"></i> All Tasks</a>
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Add Task</a>
    </div>
</div>

<div class="card">
    <div class="card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Task</th>
                        <th>Type</th>
                        <th>Related To</th>
                        <th>Due Date</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model)
                    {
                        <tr style="@(task.IsOverdue ? "background: #fee2e2;" : "")">
                            <td><a asp-action="Details" asp-route-id="@task.Id" style="font-weight: 600;">@task.Title</a></td>
                            <td><span class="badge badge-info">@task.Type</span></td>
                            <td>
                                @if (task.Customer != null)
                                {
                                    <span>@task.Customer.CompanyName</span>
                                }
                                else if (task.Lead != null)
                                {
                                    <span>@task.Lead.FullName</span>
                                }
                                else if (task.Deal != null)
                                {
                                    <span>@task.Deal.Title</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>
                                @task.DueDate.ToString("MMM dd, HH:mm")
                                @if (task.IsOverdue) { <span class="badge badge-danger">Overdue</span> }
                            </td>
                            <td>
                                <span class="badge @(task.Priority == CRM___Customer_Relationship_Management_System.Models.TaskPriority.High || task.Priority == CRM___Customer_Relationship_Management_System.Models.TaskPriority.Urgent ? "badge-danger" : task.Priority == CRM___Customer_Relationship_Management_System.Models.TaskPriority.Medium ? "badge-warning" : "badge-secondary")">
                                    @task.Priority
                                </span>
                            </td>
                            <td><span class="badge @(task.Status == CRM___Customer_Relationship_Management_System.Models.TaskStatus.Completed ? "badge-success" : "badge-primary")">@task.Status</span></td>
                            <td>
                                <div style="display: flex; gap: 0.5rem;">
                                    @if (task.Status != CRM___Customer_Relationship_Management_System.Models.TaskStatus.Completed)
                                    {
                                        <form asp-action="Complete" asp-route-id="@task.Id" method="post" style="display: inline;">
                                            <button type="submit" class="btn btn-sm btn-success" title="Complete"><i class="fas fa-check"></i></button>
                                        </form>
                                    }
                                    <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-secondary"><i class="fas fa-edit"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-check-circle"></i>
                <h3>No tasks assigned</h3>
                <p>Great! You're all caught up.</p>
            </div>
        }
    </div>
</div>
