@model CRM___Customer_Relationship_Management_System.Models.CrmTask
@{
    ViewData["Title"] = "Delete Task";
}

<div class="page-header">
    <h1 class="page-title">Delete Task</h1>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Warning:</strong> This action cannot be undone.
        </div>
        
        <div style="background: var(--bg-light); padding: 1.5rem; border-radius: var(--radius); margin-bottom: 1.5rem;">
            <h4>@Model.Title</h4>
            <p class="text-muted">
                Type: <span class="badge badge-info">@Model.Type</span><br />
                Due: @Model.DueDate.ToString("MMM dd, yyyy HH:mm")<br />
                Status: <span class="badge badge-primary">@Model.Status</span>
            </p>
        </div>
        
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
