@model CRM___Customer_Relationship_Management_System.Models.Lead
@{
    ViewData["Title"] = "Convert Lead";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Convert Lead to Customer</h1>
        <p class="page-subtitle">Convert @Model.FullName to a customer</p>
    </div>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            Converting this lead will:
            <ul style="margin: 0.5rem 0 0 1.5rem;">
                <li>Create a new customer record</li>
                <li>Create a contact from the lead information</li>
                <li>Mark the lead as "Converted"</li>
            </ul>
        </div>
        
        <div style="background: var(--bg-light); padding: 1.5rem; border-radius: var(--radius); margin-bottom: 1.5rem;">
            <h4 style="margin-bottom: 1rem;">@Model.FullName</h4>
            <p class="text-muted" style="margin: 0;">
                @if (!string.IsNullOrEmpty(Model.CompanyName)) { <span><strong>Company:</strong> @Model.CompanyName</span><br /> }
                <strong>Email:</strong> @Model.Email<br />
                @if (!string.IsNullOrEmpty(Model.Phone)) { <span><strong>Phone:</strong> @Model.Phone</span><br /> }
                <strong>Source:</strong> <span class="badge badge-info">@Model.Source</span>
            </p>
        </div>
        
        <form asp-action="ConvertConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-exchange-alt"></i>
                    Convert to Customer
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
