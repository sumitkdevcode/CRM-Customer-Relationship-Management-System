@model CRM___Customer_Relationship_Management_System.Models.Lead
@{
    ViewData["Title"] = "Delete Lead";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Delete Lead</h1>
        <p class="page-subtitle">Are you sure you want to delete this lead?</p>
    </div>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Warning:</strong> This action cannot be undone.
        </div>
        
        <div style="background: var(--bg-light); padding: 1.5rem; border-radius: var(--radius); margin-bottom: 1.5rem;">
            <h4 style="margin-bottom: 1rem;">@Model.FullName</h4>
            <p class="text-muted">
                Email: @Model.Email<br />
                Status: <span class="badge badge-warning">@Model.Status</span>
            </p>
        </div>
        
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Delete Lead
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
