@model CRM___Customer_Relationship_Management_System.Models.Lead
@{
    ViewData["Title"] = Model.FullName;
}

<div class="page-header">
    <div>
        <h1 class="page-title">@Model.FullName</h1>
        <p class="page-subtitle">Lead Details</p>
    </div>
    <div style="display: flex; gap: 0.5rem;">
        @if (Model.Status != CRM___Customer_Relationship_Management_System.Models.LeadStatus.Converted)
        {
            <a asp-action="Convert" asp-route-id="@Model.Id" class="btn btn-success">
                <i class="fas fa-exchange-alt"></i>
                Convert to Customer
            </a>
        }
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="fas fa-edit"></i>
            Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i>
            Back
        </a>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem;">
    <!-- Left Column -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Lead Info</h3>
            <span class="badge @(Model.Status == CRM___Customer_Relationship_Management_System.Models.LeadStatus.Converted ? "badge-success" : Model.Status == CRM___Customer_Relationship_Management_System.Models.LeadStatus.Qualified ? "badge-primary" : "badge-warning")">
                @Model.Status
            </span>
        </div>
        <div class="card-body">
            <div style="text-align: center; margin-bottom: 1.5rem;">
                <div style="width: 80px; height: 80px; margin: 0 auto 1rem; background: var(--warning-color); background: linear-gradient(135deg, var(--warning-color), #f97316); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: #fff; font-weight: 600;">
                    @Model.FirstName.Substring(0, 1)@Model.LastName.Substring(0, 1)
                </div>
                <h4>@Model.FullName</h4>
                @if (!string.IsNullOrEmpty(Model.JobTitle))
                {
                    <p class="text-muted">@Model.JobTitle</p>
                }
            </div>
            
            <div style="margin-bottom: 1rem;">
                <strong>Rating:</strong>
                <span style="margin-left: 0.5rem;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="fas fa-star" style="color: @(i <= Model.Rating ? "var(--warning-color)" : "var(--border-color)");"></i>
                    }
                </span>
            </div>
            
            <div style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
                <div style="margin-bottom: 0.75rem;">
                    <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Email</strong>
                    <div><a href="mailto:@Model.Email">@Model.Email</a></div>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Phone</strong>
                        <div>@Model.Phone</div>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.CompanyName))
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Company</strong>
                        <div>@Model.CompanyName</div>
                    </div>
                }
                
                <div style="margin-bottom: 0.75rem;">
                    <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Source</strong>
                    <div><span class="badge badge-info">@Model.Source</span></div>
                </div>
                
                @if (Model.EstimatedValue.HasValue)
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Estimated Value</strong>
                        <div style="color: var(--success-color); font-weight: 600; font-size: 1.25rem;">$@Model.EstimatedValue.Value.ToString("N0")</div>
                    </div>
                }
                
                @if (Model.AssignedTo != null)
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Assigned To</strong>
                        <div>@Model.AssignedTo.FullName</div>
                    </div>
                }
                
                <div style="margin-bottom: 0.75rem;">
                    <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Created</strong>
                    <div>@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                </div>
                
                @if (Model.ConvertedAt.HasValue)
                {
                    <div style="margin-bottom: 0.75rem;">
                        <strong style="color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase;">Converted</strong>
                        <div>@Model.ConvertedAt.Value.ToString("MMM dd, yyyy")</div>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <!-- Right Column -->
    <div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="card" style="margin-bottom: 1.5rem;">
                <div class="card-header">
                    <h3 class="card-title">Description</h3>
                </div>
                <div class="card-body">
                    <p>@Model.Description</p>
                </div>
            </div>
        }
        
        <!-- Tasks -->
        <div class="card" style="margin-bottom: 1.5rem;">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-tasks" style="margin-right: 0.5rem;"></i>Tasks (@Model.Tasks.Count)</h3>
                <a asp-controller="Task" asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Add
                </a>
            </div>
            <div class="card-body" style="padding: 0;">
                @if (Model.Tasks.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Due Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.Tasks.OrderBy(t => t.DueDate))
                            {
                                <tr>
                                    <td><a asp-controller="Task" asp-action="Details" asp-route-id="@task.Id">@task.Title</a></td>
                                    <td>@task.DueDate.ToString("MMM dd, yyyy")</td>
                                    <td><span class="badge badge-primary">@task.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-tasks"></i>
                        <p>No tasks yet</p>
                    </div>
                }
            </div>
        </div>
        
        <!-- Notes -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-sticky-note" style="margin-right: 0.5rem;"></i>Notes (@Model.Notes.Count)</h3>
                <a asp-controller="Note" asp-action="Create" asp-route-leadId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> Add
                </a>
            </div>
            <div class="card-body">
                @if (Model.Notes.Any())
                {
                    @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
                    {
                        <div style="padding: 1rem; background: var(--bg-light); border-radius: var(--radius); margin-bottom: 0.75rem;">
                            <div style="font-weight: 600; margin-bottom: 0.5rem;">@note.Title</div>
                            <div style="color: var(--text-muted); margin-bottom: 0.5rem;">@note.Content</div>
                            <div style="font-size: 0.75rem; color: var(--text-light);">
                                @note.CreatedBy?.FullName • @note.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-sticky-note"></i>
                        <p>No notes yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
